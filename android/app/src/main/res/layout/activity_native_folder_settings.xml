<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/folder_settings_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <TextView
            android:id="@+id/screen_heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/folder_screen_title"
            android:textAppearance="@style/TextAppearance.Runway.Title" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/folder_screen_intro"
            android:textAppearance="@style/TextAppearance.Runway.Body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/runway_status_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <View
                android:id="@+id/setup_indicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/runway_status_dot"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/setup_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:accessibilityLiveRegion="polite"
                android:text="@string/setup_connect_account"
                android:textAppearance="@style/TextAppearance.Runway.Status" />
        </LinearLayout>

        <LinearLayout
            style="@style/Widget.Runway.Section"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/server_section_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/server_section_title"
                android:textAppearance="@style/TextAppearance.Runway.SectionTitle" />

            <TextView
                android:id="@+id/server_origin_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.Runway.Body" />

            <Button
                android:id="@+id/change_server"
                style="@style/Widget.Runway.Button.Text"
                android:layout_marginTop="8dp"
                android:text="@string/change_server" />
        </LinearLayout>

        <LinearLayout
            style="@style/Widget.Runway.Section"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/pairing_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pairing_title"
                android:textAppearance="@style/TextAppearance.Runway.SectionTitle" />

            <TextView
                android:id="@+id/pairing_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:accessibilityLiveRegion="polite"
                android:text="@string/pairing_intro"
                android:textAppearance="@style/TextAppearance.Runway.Body" />

            <LinearLayout
                android:id="@+id/pairing_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:labelFor="@id/pairing_code"
                    android:text="@string/pairing_code"
                    android:textAppearance="@style/TextAppearance.Runway.Label" />

                <EditText
                    android:id="@+id/pairing_code"
                    style="@style/Widget.Runway.Input"
                    android:layout_marginTop="4dp"
                    android:importantForAutofill="no"
                    android:imeOptions="actionNext"
                    android:inputType="textCapCharacters|textNoSuggestions"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:labelFor="@id/device_label"
                    android:text="@string/device_label"
                    android:textAppearance="@style/TextAppearance.Runway.Label" />

                <EditText
                    android:id="@+id/device_label"
                    style="@style/Widget.Runway.Input"
                    android:layout_marginTop="4dp"
                    android:importantForAutofill="no"
                    android:imeOptions="actionDone"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:text="@string/device_label_default" />
            </LinearLayout>

            <Button
                android:id="@+id/forget_account"
                style="@style/Widget.Runway.Button.Text"
                android:layout_marginTop="12dp"
                android:text="@string/forget_account"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/primary_action"
            style="@style/Widget.Runway.Button.Primary"
            android:layout_marginTop="16dp"
            android:text="@string/pair_device" />

        <LinearLayout
            style="@style/Widget.Runway.Section"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/folder_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/folder_section_title"
                android:textAppearance="@style/TextAppearance.Runway.SectionTitle" />

            <TextView
                android:id="@+id/folder_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:accessibilityLiveRegion="polite"
                android:text="@string/folder_not_connected"
                android:textAppearance="@style/TextAppearance.Runway.Body" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/change_folder"
                    style="@style/Widget.Runway.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/change_folder"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/disconnect_folder"
                    style="@style/Widget.Runway.Button.Text"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/disconnect_folder"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            style="@style/Widget.Runway.Section"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/background_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/background_title"
                android:textAppearance="@style/TextAppearance.Runway.SectionTitle" />

            <TextView
                android:id="@+id/background_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:accessibilityLiveRegion="polite"
                android:text="@string/background_setup_required"
                android:textAppearance="@style/TextAppearance.Runway.Body" />

            <TextView
                android:id="@+id/last_check_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:accessibilityLiveRegion="polite"
                android:text="@string/last_check_never"
                android:textAppearance="@style/TextAppearance.Runway.Supporting" />

            <Button
                android:id="@+id/background_action"
                style="@style/Widget.Runway.Button.Secondary"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:text="@string/enable_background" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/folder_upload_ready"
            android:textAppearance="@style/TextAppearance.Runway.Supporting" />

        <Button
            android:id="@+id/return_to_runway"
            style="@style/Widget.Runway.Button.Text"
            android:layout_marginTop="16dp"
            android:text="@string/return_to_runway" />
    </LinearLayout>
</ScrollView>
