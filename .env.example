# The base Compose file permits a host binding override for local development.
# The production overlay ignores this value and pins its app port to loopback;
# use the documented ipvlan overlay when a remote reverse proxy needs access.
RUNWAY_BIND_ADDRESS="127.0.0.1"
RUNWAY_PORT="4100"
# Production should pin a full sha-* tag or image digest. latest is convenient
# for initial evaluation but is not an immutable rollback target.
RUNWAY_IMAGE="ghcr.io/deftmartian/runway:latest"

# Optional deploy/compose.ipvlan.yaml settings. This overlay follows the
# 192.168.<VLAN_TAG>.0/24 pattern and assigns the app address ending in .10.
VLAN_TAG=""
VLAN_TRUNK_INTERFACE=""
DNS_SERVER=""

# Drizzle
DATABASE_URL="postgres://runway:runway_dev_password@127.0.0.1:5432/runway"
POSTGRES_PASSWORD="runway_dev_password"
# Optional override for the app container. Defaults to the compose db service.
APP_DATABASE_URL=""
# Web and worker pools are separate. Keep their sum below PostgreSQL's available
# connection budget after reserving capacity for migrations and operator access.
APP_DATABASE_POOL_MAX="10"
WORKER_DATABASE_POOL_MAX="5"
DATABASE_CONNECT_TIMEOUT_SECONDS="10"
DATABASE_IDLE_TIMEOUT_SECONDS="30"
DATABASE_MAX_LIFETIME_SECONDS="1800"
DATABASE_STATEMENT_TIMEOUT_MS="30000"
DATABASE_IDLE_TRANSACTION_TIMEOUT_MS="30000"
# SvelteKit Node body limit. Keep above runway's 10 MB GPX limit so the app can return controlled validation errors.
BODY_SIZE_LIMIT="12M"

# Production must set HTTPS public origins. Change these together when testing
# through a hostname or address other than localhost.
ORIGIN="http://localhost:4100"
PUBLIC_APP_ORIGIN="http://localhost:4100"
# Public corresponding-source location shown to users. Forks and modified
# deployments should point this to the source for the deployed version.
PUBLIC_SOURCE_URL="https://github.com/deftmartian/runway"

# Better Auth
# Required in production. Generate with `corepack pnpm secret:generate`.
# Production accepts only the runway-secret-v1 encoding of exactly 32 random bytes.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# Optional versioned keyring for staged rotation. Generate every key with the same command.
# The first entry encrypts new data;
# later entries decrypt older envelopes. Keep BETTER_AUTH_SECRET as the legacy fallback
# during migration. Example shape only: 2:<new-secret>,1:<old-secret>
BETTER_AUTH_SECRETS=""
# Optional separate HMAC key for sign-in, signup, 2FA, and account-security rate limits.
AUTH_RATE_LIMIT_SECRET=""
# Optional fallback HMAC key for password-reset rate-limit identifiers.
PASSWORD_RESET_RATE_LIMIT_SECRET=""
# Optional separate HMAC key for short-lived Android pairing codes and
# user-scoped import receipt keys. If blank, BETTER_AUTH_SECRET is used.
ANDROID_CREDENTIAL_SECRET=""
# Required only when distributing the Android app. These values must match the
# package id and signing certificate used for the installed release APK.
ANDROID_APPLICATION_ID=""
# One or more colon-delimited SHA-256 certificate fingerprints, comma-separated.
ANDROID_CERTIFICATE_SHA256=""

# Authentik/OIDC. Leave blank in local development if Authentik is not available.
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
# Keep OIDC enrollment closed except during an intentional onboarding window.
ALLOW_OIDC_SIGNUPS="false"

# Local auth fallback.
LOCAL_AUTH_ENABLED="true"
# Keep registration closed unless the operator intentionally opens it.
ALLOW_LOCAL_SIGNUPS="false"

# Transactional email for local-account password reset.
# Proton Mail can be used through a custom-domain SMTP token or a reachable
# Proton Mail Bridge SMTP endpoint. Do not use the Proton account password here.
MAIL_ENABLED="false"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_TLS_MODE="starttls"
# Only set true for a trusted local SMTP bridge that cannot use TLS.
SMTP_ALLOW_PLAINTEXT="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="runway <runway@example.test>"

# Used by @hapi/iron to seal stored import-source secrets such as Nextcloud share passwords.
# If blank, BETTER_AUTH_SECRET is used. Production must provide one of them.
IMPORT_SECRET_KEY=""
# Comma-separated exact origins allowed for server-side Nextcloud public-share WebDAV.
# Include the scheme and any non-default port, for example https://cloud.example.com.
NEXTCLOUD_ALLOWED_ORIGINS=""
# Compose sets this explicitly for its separate worker. The web process only
# starts scheduled sync when the value is exactly true.
IMPORT_WORKER_ENABLED=""
# Audit events expire after 365 days by default. Set an integer from 1 to 3650,
# or use the exact value disabled only when indefinite retention is intentional.
AUDIT_EVENT_RETENTION_DAYS=""

# Passkey/WebAuthn.
# Leave blank in production to derive it from PUBLIC_APP_ORIGIN, or set it to
# the exact HTTPS deployment hostname. For local passkey testing, open
# http://localhost:4100 and use localhost here. Plain LAN HTTP is not a secure
# browser context for WebAuthn.
PASSKEY_RP_ID=""
PASSKEY_RP_NAME="runway"
