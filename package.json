{
	"name": "runway",
	"private": true,
	"version": "0.1.1",
	"description": "A self-hosted running planner and activity ledger for comparing recommendations, edits, and recorded work.",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/deftmartian/runway.git"
	},
	"homepage": "https://github.com/deftmartian/runway#readme",
	"bugs": {
		"url": "https://github.com/deftmartian/runway/issues"
	},
	"type": "module",
	"packageManager": "pnpm@10.32.0",
	"engines": {
		"node": ">=24 <25"
	},
	"scripts": {
		"dev": "vite dev --host 0.0.0.0 --port 4100",
		"build": "vite build",
		"assets:pwa": "node scripts/generate-pwa-assets.mjs",
		"assets:pwa:check": "node scripts/generate-pwa-assets.mjs --check",
		"secret:generate": "node scripts/generate-secret.mjs",
		"preview": "node scripts/run-preview.mjs",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . --max-warnings=0 && stylelint 'src/**/*.css'",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test": "corepack pnpm test:unit && corepack pnpm test:e2e",
		"test:e2e": "node scripts/run-browser-tests.mjs e2e",
		"test:visual": "node scripts/run-browser-tests.mjs visual",
		"test:visual:update": "node scripts/run-browser-tests.mjs visual --update-snapshots",
		"verify": "corepack pnpm lint && corepack pnpm check && corepack pnpm test:unit && corepack pnpm build",
		"verify:docs": "node scripts/verify-docs.mjs",
		"verify:browser": "corepack pnpm test:e2e",
		"verify:docker": "docker build -t runway .",
		"verify:compose": "docker compose config -q",
		"verify:compose:production": "node scripts/verify-production-compose.mjs",
		"verify:android": "node scripts/verify-android.mjs",
		"verify:android:build": "android/gradlew -p android --no-daemon --dependency-verification strict -PrunwayOrigin=https://runway.example.test lint test assembleDebug && node scripts/verify-android-artifact.mjs debug",
		"verify:android:release": "node scripts/verify-android-release.mjs",
		"verify:caddy": "node scripts/verify-caddy.mjs",
		"verify:dependencies": "node scripts/verify-dependencies.mjs",
		"verify:image": "node scripts/verify-image.mjs",
		"verify:migrations": "node scripts/verify-fresh-migrations.mjs",
		"verify:pwa": "vitest run src/lib/pwa/*.spec.ts",
		"verify:pwa:assets": "corepack pnpm assets:pwa:check",
		"verify:preview": "node scripts/verify-preview.mjs",
		"verify:preview:local": "node scripts/verify-local-preview.mjs",
		"verify:full": "corepack pnpm verify:docs && corepack pnpm verify:dependencies && corepack pnpm verify && corepack pnpm verify:pwa && corepack pnpm verify:migrations && corepack pnpm test:e2e && corepack pnpm test:visual && corepack pnpm verify:pwa:assets && corepack pnpm verify:compose && corepack pnpm verify:compose:production && corepack pnpm verify:android && corepack pnpm verify:android:build && corepack pnpm verify:android:release && corepack pnpm verify:caddy && corepack pnpm verify:docker",
		"db:start": "docker compose up -d db",
		"db:push": "drizzle-kit push",
		"db:push:force": "drizzle-kit push --force",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:runtime": "node scripts/run-migrations.mjs",
		"db:backup": "node scripts/backup-database.mjs",
		"db:backup:verify": "node scripts/verify-database-backup.mjs",
		"db:restore": "node scripts/restore-database.mjs",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@types/nodemailer": "^8.0.0",
		"@types/qrcode": "^1.5.6",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"stylelint": "^17.11.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@better-auth/passkey": "^1.6.23",
		"@hapi/iron": "^7.0.1",
		"better-auth": "~1.6.23",
		"better-call": "1.3.7",
		"drizzle-orm": "^0.45.2",
		"fast-xml-parser": "^5.10.1",
		"fast-xml-validator": "^1.4.0",
		"kysely": "0.29.4",
		"nodemailer": "^9.0.3",
		"postgres": "^3.4.9",
		"qrcode": "^1.5.4",
		"zod": "^4.4.3"
	},
	"pnpm": {
		"overrides": {
			"cookie": "^1.1.1",
			"devalue": "^5.8.1",
			"drizzle-orm": "^0.45.2",
			"esbuild": "^0.28.1",
			"kysely": "0.29.4",
			"lodash": "^4.18.1"
		}
	}
}
